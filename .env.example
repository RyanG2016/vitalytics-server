APP_NAME=Vitalytics
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://your-domain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (MySQL/MariaDB)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vitalytics
DB_USERNAME=vitalytics_user
DB_PASSWORD=

# Cache & Session
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail (optional - for alert emails)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="alerts@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

#--------------------------------------------------------------------------
# Vitalytics Configuration
#--------------------------------------------------------------------------

# Data Retention (days)
VITALYTICS_RETENTION_DAYS=90

# Queue name for processing events
VITALYTICS_QUEUE=default

# IP Geolocation
VITALYTICS_GEOLOCATION_ENABLED=true

# Alerts
VITALYTICS_ALERTS_ENABLED=true
VITALYTICS_ALERTS_INTERVAL=5
VITALYTICS_ALERTS_COOLDOWN=30
VITALYTICS_SLACK_WEBHOOK=

# Rate Limiting
VITALYTICS_RATE_LIMIT_ENABLED=true
VITALYTICS_RATE_LIMIT_MAX=1000
VITALYTICS_RATE_LIMIT_DECAY=1

#--------------------------------------------------------------------------
# API Keys for Products
# Generate secure keys with: php artisan vitalytics:generate-key
#--------------------------------------------------------------------------

# Example: My App
VITALYTICS_KEY_MYAPP_IOS=
VITALYTICS_KEY_MYAPP_ANDROID=
VITALYTICS_KEY_MYAPP_WEB=

# Example: Another App
VITALYTICS_KEY_ANOTHERAPP_WINDOWS=
VITALYTICS_KEY_ANOTHERAPP_MACOS=
